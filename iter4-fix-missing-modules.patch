+export type Visibility = "everyone" | "friends" | "hidden";
+export type FeedDetail = "color" | "icon" | "text";
+
+/**
+ * Lightweight prefs for MVP.
+ * Later this can be persisted per-user in Supabase.
+ */
+export type Prefs = {
+  visibility: Visibility;
+  detail: FeedDetail;
+  invisibleToday: boolean;
+};
+
+export const defaultPrefs: Prefs = {
+  visibility: "friends",
+  detail: "icon",
+  invisibleToday: false,
+};
+
