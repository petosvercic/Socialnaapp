+"use client";
+
+import { useEffect, useMemo, useState } from "react";
+import type { FeedDetail, Visibility } from "@/lib/prefs/types";
+import { defaultPrefs } from "@/lib/prefs/types";
+import { loadPrefs, resetPrefs, updatePrefs } from "@/lib/prefs/storage";
+import { getLatestCheckin } from "@/lib/mood/storage";
+import type { MoodColor } from "@/lib/mood/types";
+
+function dotClass(color: MoodColor | "gray") {
+  switch (color) {
+    case "green":
+      return "bg-emerald-500";
+    case "yellow":
+      return "bg-yellow-400";
+    case "orange":
+      return "bg-orange-500";
+    case "red":
+      return "bg-rose-500";
+    default:
+      return "bg-zinc-300 dark:bg-zinc-700";
+  }
+}
+
+export default function SettingsPage() {
+  const [hydrated, setHydrated] = useState(false);
+
+  const [saved, setSaved] = useState(defaultPrefs);
+  const [draftVisibility, setDraftVisibility] = useState<Visibility>(defaultPrefs.visibility);
+  const [draftDetail, setDraftDetail] = useState<FeedDetail>(defaultPrefs.detail);
+  const [draftInvisibleToday, setDraftInvisibleToday] = useState<boolean>(defaultPrefs.invisibleToday);
+
+  useEffect(() => {
+    const prefs = loadPrefs();
+    setSaved(prefs);
+    setDraftVisibility(prefs.visibility);
+    setDraftDetail(prefs.detail);
+    setDraftInvisibleToday(prefs.invisibleToday);
+    setHydrated(true);
+  }, []);
+
+  const effectiveVisibility: Visibility = useMemo(() => {
+    return draftInvisibleToday ? "hidden" : draftVisibility;
+  }, [draftInvisibleToday, draftVisibility]);
+
+  const dirty = useMemo(() => {
+    if (!hydrated) return false;
+    return (
+      saved.visibility !== draftVisibility ||
+      saved.detail !== draftDetail ||
+      saved.invisibleToday !== draftInvisibleToday
+    );
+  }, [draftDetail, draftInvisibleToday, draftVisibility, hydrated, saved.detail, saved.invisibleToday, saved.visibility]);
+
+  const latest = useMemo(() => {
+    if (!hydrated) return null;
+    return getLatestCheckin("general");
+  }, [hydrated]);
+
+  const preview = useMemo(() => {
+    const res = latest?.result;
+    const color = res?.color ?? "gray";
+    const icon = res?.icon ?? "";
+    const label = res?.status ?? "Bez check-inu";
+    const text = res ? `${label}` : "Sprav dnešný check-in.";
+    return { color, icon, label, text };
+  }, [latest]);
+
+  function confirm() {
+    const next = { visibility: draftVisibility, detail: draftDetail, invisibleToday: draftInvisibleToday };
+    updatePrefs(next);
+    setSaved(next);
+  }
+
+  function cancel() {
+    setDraftVisibility(saved.visibility);
+    setDraftDetail(saved.detail);
+    setDraftInvisibleToday(saved.invisibleToday);
+  }
+
+  return (
+    <div className="space-y-4">
+      <h1 className="text-lg font-semibold tracking-tight">Nastavenia</h1>
+
+      {dirty && (
+        <div className="rounded-2xl border border-amber-200 bg-amber-50 p-3 text-sm text-amber-900 dark:border-amber-900/40 dark:bg-amber-950/30 dark:text-amber-100">
+          Máš neuložené zmeny. Vyber <span className="font-medium">Potvrdiť</span> alebo <span className="font-medium">Zrušiť</span>.
+        </div>
+      )}
+
+      <div className="flex gap-2">
+        <button
+          type="button"
+          disabled={!dirty}
+          onClick={confirm}
+          className={[
+            "inline-flex flex-1 items-center justify-center rounded-xl px-4 py-2 text-sm font-medium",
+            dirty
+              ? "bg-zinc-950 text-white hover:bg-zinc-800 dark:bg-white dark:text-zinc-950 dark:hover:bg-zinc-200"
+              : "cursor-not-allowed border border-zinc-200 bg-white text-zinc-400 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-500",
+          ].join(" ")}
+        >
+          Potvrdiť
+        </button>
+        <button
+          type="button"
+          disabled={!dirty}
+          onClick={cancel}
+          className={[
+            "inline-flex flex-1 items-center justify-center rounded-xl border px-4 py-2 text-sm font-medium",
+            dirty
+              ? "border-zinc-200 bg-white hover:bg-zinc-50 dark:border-zinc-800 dark:bg-zinc-900 dark:hover:bg-zinc-800"
+              : "cursor-not-allowed border-zinc-200 bg-white text-zinc-400 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-500",
+          ].join(" ")}
+        >
+          Zrušiť
+        </button>
+      </div>
+
+      <div className="rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm dark:border-zinc-800 dark:bg-zinc-900">
+        <div className="text-sm font-medium">Viditeľnosť dnes</div>
+        <p className="mt-1 text-sm text-zinc-600 dark:text-zinc-300">
+          Aby to nebolo toxické. Tvoje dáta, tvoja voľba.
+        </p>
+
+        <label className="mt-3 flex items-center justify-between gap-3 rounded-xl border border-zinc-200 bg-zinc-50 px-3 py-2 text-sm dark:border-zinc-800 dark:bg-zinc-950">
+          <div>
+            <div className="font-medium">Invisible today</div>
+            <div className="text-xs text-zinc-600 dark:text-zinc-300">
+              Skryje ťa z feedu (bez vysvetľovania ľuďom).
+            </div>
+          </div>
+          <input
+            type="checkbox"
+            checked={draftInvisibleToday}
+            onChange={(e) => setDraftInvisibleToday(e.target.checked)}
+            className="h-5 w-5 accent-zinc-950 dark:accent-white"
+            aria-label="Invisible today"
+          />
+        </label>
+
+        <div className="mt-3 grid grid-cols-3 gap-2">
+          {[
+            { id: "everyone", label: "Všetci" },
+            { id: "friends", label: "Priatelia" },
+            { id: "hidden", label: "Skryté" },
+          ].map((opt) => (
+            <button
+              key={opt.id}
+              type="button"
+              onClick={() => setDraftVisibility(opt.id as Visibility)}
+              className={[
+                "rounded-xl border px-3 py-2 text-sm",
+                effectiveVisibility === opt.id
+                  ? "border-zinc-900 bg-zinc-950 text-white dark:border-zinc-200 dark:bg-white dark:text-zinc-950"
+                  : "border-zinc-200 bg-white hover:bg-zinc-50 dark:border-zinc-800 dark:bg-zinc-900 dark:hover:bg-zinc-800",
+              ].join(" ")}
+            >
+              {opt.label}
+            </button>
+          ))}
+        </div>
+
+        <div className="mt-3 rounded-xl border border-zinc-200 bg-zinc-50 p-3 text-sm dark:border-zinc-800 dark:bg-zinc-950">
+          <div className="text-xs font-semibold text-zinc-600 dark:text-zinc-300">Aktuálne</div>
+          <div className="mt-1">
+            {effectiveVisibility === "hidden"
+              ? "Skryté"
+              : effectiveVisibility === "friends"
+              ? "Len priatelia"
+              : "Všetci"}
+          </div>
+        </div>
+      </div>
+
+      <div className="rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm dark:border-zinc-800 dark:bg-zinc-900">
+        <div className="text-sm font-medium">Detail v feede</div>
+        <p className="mt-1 text-sm text-zinc-600 dark:text-zinc-300">
+          Čo uvidia ostatní o tebe: len farbu, farbu + ikonu, alebo aj krátky text.
+        </p>
+        <p className="mt-2 text-xs text-zinc-500 dark:text-zinc-400">
+          Pozn.: toto nemení, čo ty vidíš o ostatných. Len čo oni vidia o tebe.
+        </p>
+
+        <div className="mt-3 grid grid-cols-3 gap-2">
+          {[
+            { id: "color", label: "Farba" },
+            { id: "icon", label: "Ikona" },
+            { id: "text", label: "Text" },
+          ].map((opt) => (
+            <button
+              key={opt.id}
+              type="button"
+              onClick={() => setDraftDetail(opt.id as FeedDetail)}
+              className={[
+                "rounded-xl border px-3 py-2 text-sm",
+                draftDetail === opt.id
+                  ? "border-zinc-900 bg-zinc-950 text-white dark:border-zinc-200 dark:bg-white dark:text-zinc-950"
+                  : "border-zinc-200 bg-white hover:bg-zinc-50 dark:border-zinc-800 dark:bg-zinc-900 dark:hover:bg-zinc-800",
+              ].join(" ")}
+            >
+              {opt.label}
+            </button>
+          ))}
+        </div>
+
+        <div className="mt-3 rounded-xl border border-zinc-200 bg-zinc-50 p-3 text-sm dark:border-zinc-800 dark:bg-zinc-950">
+          <div className="text-xs font-semibold text-zinc-600 dark:text-zinc-300">Náhľad</div>
+          <div className="mt-1">
+            <div className="flex items-center gap-2">
+              <div className={["h-3 w-3 rounded-full", dotClass(preview.color as any)].join(" ")} />
+              {draftDetail === "icon" && <span className="text-sm">{preview.icon || "·"}</span>}
+              {draftDetail === "text" && (
+                <span className="text-sm">{preview.text}</span>
+              )}
+              {draftDetail === "color" && (
+                <span className="text-sm text-zinc-600 dark:text-zinc-300">{preview.label}</span>
+              )}
+            </div>
+          </div>
+        </div>
+      </div>
+
+      <div className="rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm dark:border-zinc-800 dark:bg-zinc-900">
+        <div className="text-sm font-medium">Reset</div>
+        <p className="mt-1 text-sm text-zinc-600 dark:text-zinc-300">
+          Ak si to naklikal v hneve. Stáva sa. Ľuďom.
+        </p>
+        <button
+          type="button"
+          onClick={() => {
+            const p = resetPrefs();
+            setSaved(p);
+            setDraftVisibility(p.visibility);
+            setDraftDetail(p.detail);
+            setDraftInvisibleToday(p.invisibleToday);
+          }}
+          className="mt-3 inline-flex rounded-xl border border-zinc-200 bg-white px-4 py-2 text-sm font-medium hover:bg-zinc-50 dark:border-zinc-800 dark:bg-zinc-900 dark:hover:bg-zinc-800"
+        >
+          Resetovať nastavenia
+        </button>
+      </div>
+    </div>
+  );
+}
