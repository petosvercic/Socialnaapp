--- /mnt/data/work/iter3_base/Socialnaapp-main/src/lib/mood/prefs.ts	1970-01-01 00:00:00.000000000 +0000
+++ /mnt/data/work/iter3/Socialnaapp-main/src/lib/mood/prefs.ts	2026-03-01 23:57:28.364293515 +0000
@@ -0,0 +1,55 @@
+export type FeedVisibility = "everyone" | "friends" | "hidden";
+export type FeedDetail = "color" | "icon" | "text";
+
+export type VioraPrefs = {
+  /** Default visibility for your daily status in the feed. */
+  visibility: FeedVisibility;
+  /** What others see when your status is visible. */
+  detail: FeedDetail;
+  /** If set to today's local date, you're invisible for the day. */
+  invisibleDateISO: string | null;
+};
+
+const KEY = "viora.prefs.v1";
+
+export const defaultPrefs: VioraPrefs = {
+  visibility: "friends",
+  detail: "icon",
+  invisibleDateISO: null,
+};
+
+function safeParse(json: string | null): Partial<VioraPrefs> | null {
+  if (!json) return null;
+  try {
+    const data = JSON.parse(json) as unknown;
+    if (!data || typeof data !== "object") return null;
+    return data as Partial<VioraPrefs>;
+  } catch {
+    return null;
+  }
+}
+
+export function readPrefs(): VioraPrefs {
+  if (typeof window === "undefined") return defaultPrefs;
+  const partial = safeParse(window.localStorage.getItem(KEY));
+  return {
+    ...defaultPrefs,
+    ...(partial ?? {}),
+  };
+}
+
+export function writePrefs(next: VioraPrefs) {
+  if (typeof window === "undefined") return;
+  window.localStorage.setItem(KEY, JSON.stringify(next));
+}
+
+export function isInvisibleToday(dateISO: string, prefs: VioraPrefs): boolean {
+  return prefs.invisibleDateISO === dateISO;
+}
+
+export function setInvisibleToday(dateISO: string, enabled: boolean, prefs: VioraPrefs): VioraPrefs {
+  return {
+    ...prefs,
+    invisibleDateISO: enabled ? dateISO : null,
+  };
+}
