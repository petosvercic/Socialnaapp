+    setPings(next);

+    savePings(next);

+  }

+

+  const inviteCode = useMemo(() => {

+    const base = "viora-" + (typeof window !== "undefined" ? window.location.host : "local");

+    let hash = 0;

+    for (let i = 0; i < base.length; i++) hash = (hash * 31 + base.charCodeAt(i)) >>> 0;

+    return hash.toString(36).slice(0, 8);

+  }, []);

+

+  const inviteUrl = useMemo(() => {

+    if (typeof window === "undefined") return `/invite/${inviteCode}`;

+    return `${window.location.origin}/invite/${inviteCode}`;

+  }, [inviteCode]);

+

+  async function copyInvite() {

+    try {

+      await navigator.clipboard.writeText(inviteUrl);

+    } catch {

+      // ignore

+    }

+  }

+

+  const myPreview = useMemo(() => {

+    if (!latest) {

+      return { colorEmoji: "⚪", icon: "", status: "Žiadny záznam" };

+    }

+    return {

+      colorEmoji: colorEmoji(latest.result.color),

+      icon: latest.result.icon,

+      status: latest.result.status,

+    };

+  }, [latest]);

+

+  return (

+    <div className="space-y-4">

+      <div className="flex items-center justify-between">

+        <h1 className="text-lg font-semibold tracking-tight">Priatelia</h1>

+        <Link href="/settings" className="text-sm text-zinc-600 hover:underline dark:text-zinc-300">

+          Nastavenia

+        </Link>

+      </div>

+

+      <div className="rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm dark:border-zinc-800 dark:bg-zinc-900">

+        <div className="text-sm font-medium">Tvoj zdieľaný stav</div>

+        <p className="mt-1 text-sm text-zinc-600 dark:text-zinc-300">

+          Toto je to, čo by dnes videli ostatní. (Nie, zatiaľ to nepushujeme do DB.)

+        </p>

+

+        <div className="mt-3 flex items-center justify-between rounded-xl border border-zinc-200 bg-zinc-50 px-3 py-2 text-sm dark:border-zinc-800 dark:bg-zinc-950">

+          <div className="flex items-center gap-3">

+            <div className="h-3 w-3 rounded-full bg-zinc-300 dark:bg-zinc-700" />

+            <div>

+              <div className="text-sm font-medium">

+                {myEffectiveVisibility === "hidden" ? "Skrytý dnes" : "Viditeľný"}

+              </div>

+              <div className="text-xs text-zinc-600 dark:text-zinc-300">

+                {myEffectiveVisibility === "hidden"

+                  ? "Invisible today alebo Skryté."

+                  : "Zdieľaš: " + (prefs.detail === "color" ? "farbu" : prefs.detail === "icon" ? "ikonu" : "text") }

+              </div>

+            </div>

+          </div>

+

+          <div className="text-sm">

+            {myEffectiveVisibility === "hidden" ? (

+              <span className="text-zinc-500 dark:text-zinc-400">—</span>

+            ) : (

+              renderMySharedPreview(prefs.detail, myPreview.icon, myPreview.status, myPreview.colorEmoji)

+            )}

+          </div>

+        </div>

+

+        <p className="mt-3 text-xs text-zinc-500 dark:text-zinc-400">

+          Pozn.: Nastavenia menia <span className="font-medium">čo zdieľaš ty</span>. To, čo vidíš o iných, závisí od toho,

+          čo zdieľajú oni.

+        </p>

+      </div>

+

+      <div className="rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm dark:border-zinc-800 dark:bg-zinc-900">

+        <div className="text-sm font-medium">Feed</div>

+        <div className="mt-3 space-y-2">

+          {friends.map((f) => (

+            <div

