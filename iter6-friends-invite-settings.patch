+import { useEffect, useMemo, useState } from "react";

+import Link from "next/link";

+import type { FeedDetail, Visibility } from "@/lib/prefs/types";

+import { loadPrefs } from "@/lib/prefs/storage";

+import { getLatestCheckin } from "@/lib/mood/storage";

+

+type SharePrefs = {

+  visibility: Visibility;

+  detail: FeedDetail;

+  invisibleToday: boolean;

+};

+

+type FriendState = {

+  id: string;

+  name: string;

+  color: "green" | "yellow" | "orange" | "red" | "gray";

+  label: string;

+  icon: string;

+  updatedAt: string;

+  share: SharePrefs;

+};

+

+type PingKind = "🫶" | "☕" | "👀";

+

+const PING_KEY = "viora:pings:v1";

+

+function chipColor(color: FriendState["color"]) {

+  switch (color) {

+    case "green":

+      return "bg-emerald-500";

+    case "yellow":

+      return "bg-yellow-400";

+    case "orange":

+      return "bg-orange-500";

+    case "red":

+      return "bg-rose-500";

+    default:

+      return "bg-zinc-300 dark:bg-zinc-700";

+  }

+}

+

+function loadPings(): Array<{ at: string; to: string; kind: PingKind }> {

+  if (typeof window === "undefined") return [];

+  try {

+    const raw = window.localStorage.getItem(PING_KEY);

+    return raw ? (JSON.parse(raw) as any[]) : [];

+  } catch {

+    return [];

+  }

+}

+

+function savePings(rows: Array<{ at: string; to: string; kind: PingKind }>) {

+  if (typeof window === "undefined") return;

+  try {

+    window.localStorage.setItem(PING_KEY, JSON.stringify(rows.slice(0, 25)));

+  } catch {}

+}

+

+function renderSharedLine(f: FriendState) {

+  // What the FRIEND shares about themselves (not your choice).

+  if (f.share.invisibleToday || f.share.visibility === "hidden") {

+    return <span className="text-xs text-zinc-500 dark:text-zinc-400">skrytý dnes</span>;

+  }

+

+  if (f.share.detail === "color") {

+    return <span className="text-xs text-zinc-500 dark:text-zinc-400">{f.updatedAt}</span>;

+  }

+

+  if (f.share.detail === "icon") {

+    return (

+      <span className="text-xs text-zinc-600 dark:text-zinc-300">

+        {f.icon} • {f.updatedAt}

+      </span>

+    );

+  }

+

+  return (

+    <span className="text-xs text-zinc-600 dark:text-zinc-300">

+      {f.label} • {f.updatedAt}

+    </span>

+  );

+}

+

+function renderMySharedPreview(detail: FeedDetail, icon: string, status: string, colorEmoji: string) {

+  if (detail === "color") return <span>{colorEmoji}</span>;

+  if (detail === "icon") return <span>{colorEmoji} {icon}</span>;

+  return <span>{colorEmoji} {status}</span>;

+}

+

+function colorEmoji(color: "green" | "yellow" | "orange" | "red") {

+  switch (color) {

+    case "green": return "🟢";

+    case "yellow": return "🟡";

+    case "orange": return "🟠";

+    case "red": return "🔴";

+  }

+}

+

+export function FriendsClient() {

+  const [pings, setPings] = useState<Array<{ at: string; to: string; kind: PingKind }>>([]);

+  const [prefs, setPrefs] = useState(() => loadPrefs());

+

+  const latest = useMemo(() => getLatestCheckin("general"), []);

+  const myEffectiveVisibility: Visibility = prefs.invisibleToday ? "hidden" : prefs.visibility;

+

+  const friends = useMemo<FriendState[]>(

+    () => [

+      {

+        id: "a1",

+        name: "Nika",

+        color: "green",

+        label: "v pohode",

+        icon: "🌿",

+        updatedAt: "dnes",

+        share: { visibility: "friends", detail: "icon", invisibleToday: false },

+      },

+      {

+        id: "b2",

+        name: "Matej",

+        color: "yellow",

+        label: "kolísavý mód",

+        icon: "🧭",

+        updatedAt: "dnes",

+        share: { visibility: "friends", detail: "text", invisibleToday: false },

+      },

+      {

+        id: "c3",

+        name: "Zuzka",

+        color: "orange",

+        label: "preťažená",

+        icon: "🔥",

+        updatedAt: "včera",

+        share: { visibility: "everyone", detail: "color", invisibleToday: false },

+      },

+      {

+        id: "d4",

+        name: "Robo",

+        color: "red",

+        label: "neotravovať",

+        icon: "🧱",

+        updatedAt: "dnes",

+        share: { visibility: "hidden", detail: "text", invisibleToday: true },

+      },

