@@ -0,0 +1,92 @@
+"use client";
+
+import Link from "next/link";
+import { useMemo, useState } from "react";
+import { VioraMark } from "@/components/brand/VioraMark";
+
+export default function InvitePage({ params }: { params: { code: string } }) {
+  const [copied, setCopied] = useState(false);
+
+  const inviteUrl = useMemo(() => {
+    if (typeof window === "undefined") return `/invite/${params.code}`;
+    return `${window.location.origin}/invite/${params.code}`;
+  }, [params.code]);
+
+  async function copy() {
+    try {
+      await navigator.clipboard.writeText(inviteUrl);
+      setCopied(true);
+      window.setTimeout(() => setCopied(false), 1400);
+    } catch {
+      // ignore
+    }
+  }
+
+  return (
+    <div className="mx-auto w-full max-w-2xl space-y-4">
+      <div className="rounded-2xl border border-zinc-200 bg-white/80 p-5 shadow-sm backdrop-blur dark:border-zinc-800 dark:bg-zinc-950/50">
+        <div className="flex items-start justify-between gap-4">
+          <div>
+            <div className="flex items-center gap-2">
+              <VioraMark className="h-5 w-5" />
+              <h1 className="text-lg font-semibold tracking-tight">Pozvánka do Viory</h1>
+            </div>
+            <p className="mt-2 text-sm text-zinc-600 dark:text-zinc-300">
+              MVP verzia: zatiaľ nič „nepotvrdzuje“ ani nevytvára priateľstvo. Toto je len landing stránka, aby link
+              nepadal na 404.
+            </p>
+          </div>
+          <span className="rounded-full border border-zinc-200 bg-white px-3 py-1 text-xs font-medium text-zinc-700 dark:border-zinc-800 dark:bg-zinc-950 dark:text-zinc-200">
+            MVP
+          </span>
+        </div>
+
+        <div className="mt-4 rounded-xl border border-zinc-200 bg-zinc-50 p-3 dark:border-zinc-800 dark:bg-zinc-950">
+          <div className="text-xs text-zinc-500 dark:text-zinc-400">Kód pozvánky</div>
+          <div className="mt-1 font-mono text-sm font-semibold tracking-wide">{params.code}</div>
+          <div className="mt-2 text-xs text-zinc-500 dark:text-zinc-400">Link</div>
+          <div className="mt-1 break-all font-mono text-xs text-zinc-700 dark:text-zinc-200">{inviteUrl}</div>
+        </div>
+
+        <div className="mt-4 flex flex-col gap-2 sm:flex-row">
+          <Link
+            href="/"
+            className="inline-flex items-center justify-center rounded-xl bg-zinc-950 px-4 py-2 text-sm font-medium text-white hover:bg-zinc-800 dark:bg-white dark:text-zinc-950 dark:hover:bg-zinc-200"
+          >
+            Otvoriť Vioru
+          </Link>
+          <button
+            type="button"
+            onClick={copy}
+            className="inline-flex items-center justify-center rounded-xl border border-zinc-200 bg-white px-4 py-2 text-sm font-medium hover:bg-zinc-50 dark:border-zinc-800 dark:bg-zinc-900 dark:hover:bg-zinc-800"
+          >
+            {copied ? "Skopírované" : "Kopírovať link"}
+          </button>
+        </div>
+      </div>
+    </div>
+  );
+}
+
